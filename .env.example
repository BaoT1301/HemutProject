# ── Required ──────────────────────────────────────────────────────────────────

# OpenAI API key (GPT-4o-mini for 3 chained AI calls)
# https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Tavily Search API key (External source #1 — company context + news fallback)
# Free tier: 1,000 searches/month — no deployment restrictions
# https://app.tavily.com/
TAVILY_API_KEY=tvly-...

# Resend email API key
# https://resend.com/api-keys
RESEND_API_KEY=re_...

# Resend sender address — must be from a verified domain in your Resend account
# For testing only (sends only to YOUR Resend account email): onboarding@resend.dev
# For production (sends to anyone): noreply@yourdomain.com
RESEND_FROM_EMAIL=noreply@yourdomain.com

# ── Optional ──────────────────────────────────────────────────────────────────

# API key for upload/status/download endpoints (auth disabled if not set)
# Set this in production to prevent unauthorized API usage
# API_KEY=your-secret-key-here

# External sources requiring NO API key (free, always available):
#   - Google News RSS (primary news source)
#   - Wikipedia REST API (company size/context)
#   - GDELT News API (last-resort news fallback)
